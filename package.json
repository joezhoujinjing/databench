{
  "name": "databench-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "openapi:check": "turbo run openapi:check",
    "spike:s1": "node scripts/spikes/s1-determinism.mjs --write",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^24.0.0",
    "hash-wasm": "4.12.0",
    "lefthook": "^1.11.0",
    "nodejs-polars": "0.25.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "tsup": "^8.3.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}

{
  "name": "@databench/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "databench": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --clean && tsc --emitDeclarationOnly",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node ../../scripts/with-test-db-schema.mjs databench_test_cli pnpm --dir ../.. exec prisma migrate deploy && node ../../scripts/with-test-db-schema.mjs databench_test_cli vitest run --passWithNoTests"
  },
  "dependencies": {
    "@databench/schema": "workspace:*",
    "@databench/workspace": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
